<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent_primary"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/rounded_corner_bg"
            android:gravity="center"
            android:text="🧠"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="ScholarMind"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your free account"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleSignUp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue with Google"
                android:textColor="@color/text_primary"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border_subtle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_subtle" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginHorizontal="8dp" android:text="or sign up with email" android:textColor="@color/text_muted" android:textSize="12sp" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/border_subtle" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FULL NAME" android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@color/surface_base"
                android:hint="Your full name"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="UNIVERSITY EMAIL" android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/etSignUpEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@color/surface_base"
                android:hint="you@university.edu"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PASSWORD" android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/etSignUpPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@color/surface_base"
                android:hint="••••••••••••"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:paddingHorizontal="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="4">
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_marginEnd="4dp" android:layout_weight="1" android:background="@color/accent_success" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_marginEnd="4dp" android:layout_weight="1" android:background="@color/accent_success" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_marginEnd="4dp" android:layout_weight="1" android:background="@color/accent_success" />
                <View android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="@color/accent_warning" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Strong password" android:textColor="@color/accent_success" android:textSize="12sp" />

            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="I agree to ScholarMind's Terms of Service and Privacy Policy"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/accent_primary"
                android:text="Sign Up Free"
                android:textColor="@color/text_primary"
                app:cornerRadius="14dp" />

            <TextView
                android:id="@+id/tvSignInPrompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="Already have an account? Sign In"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
