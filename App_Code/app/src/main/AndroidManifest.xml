<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network & storage -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <!-- Foreground service & notification (podcast player) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application android:networkSecurityConfig="@xml/network_security_config" android:usesCleartextTraffic="${usesCleartextTraffic}" android:allowBackup="true" android:icon="@mipmap/ic_launcher" android:label="@string/app_name" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/Theme.ScholarMind">
        <activity android:name=".SplashActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:name=".MainActivity" android:exported="false"/>
        <activity android:name=".SignUpActivity" android:exported="false"/>
        <activity android:name=".ForgotPasswordActivity" android:exported="false"/>
        <activity android:name=".HomeActivity" android:exported="false"/>
        <activity android:name=".UploadActivity" android:exported="false"/>
        <activity android:name=".ProcessingActivity" android:exported="false"/>
        <activity android:name=".ModeSelectActivity" android:exported="false"/>
        <activity android:name=".BeginnerModeActivity" android:exported="false"/>
        <activity android:name=".TechnicalModeActivity" android:exported="false"/>
        <activity android:name=".ChatModeActivity" android:exported="false"/>
        <activity android:name=".SimplifierActivity" android:exported="false"/>
        <activity android:name=".SummaryActivity" android:exported="false"/>
        <activity android:name=".CitationsActivity" android:exported="false"/>
        <activity android:name=".QuizModeActivity" android:exported="false"/>
        <!--  Podcast Flow  -->
        <activity android:name=".PodcastSetupActivity" android:exported="false"/>
        <activity android:name=".PodcastProgressActivity" android:exported="false"/>
        <activity android:name=".PodcastPlayerActivity" android:exported="false"/>
        <!--  Dashboard Hub + Feature Screens  -->
        <activity android:name=".DashboardActivity" android:exported="false"/>
        <activity android:name=".AddReferencesActivity" android:exported="false"/>
        <activity android:name=".PeerReviewActivity" android:exported="false"/>
        <activity android:name=".SearchPapersActivity" android:exported="false"/>
        <activity android:name=".PaperDetailsActivity" android:exported="false"/>

        <!--  Podcast Foreground Service  -->
        <service
            android:name=".PodcastPlayerService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false"/>

        <!--  Notification action receiver (inner class)  -->
        <receiver
            android:name=".PodcastPlayerService$NotificationActionReceiver"
            android:exported="false"/>
    </application>
</manifest>
